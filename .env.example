# RAGStack — shared environment template
# Copy to .env and adjust as needed.

# --- API ---
PORT=8080                      # Go default; Python uses 8000
LOG_LEVEL=info                 # debug | info | warn | error

# --- Infrastructure ---
QDRANT_URL=http://localhost:6333
ELASTICSEARCH_URL=http://localhost:9200
NEO4J_URI=bolt://localhost:7687
NEO4J_PASSWORD=neo4j
POSTGRES_URL=postgres://ragstack:ragstack@localhost:5432/ragstack
REDIS_URL=redis://localhost:6379

# --- Models (self-hosted) ---
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
CROSSENCODER_MODEL=BAAI/bge-reranker-v2-m3
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct

# --- Sidecars ---
EMBEDDING_SIDECAR_URL=http://localhost:50053
CROSSENCODER_SIDECAR_URL=http://localhost:50052
FAISS_SIDECAR_URL=http://localhost:50051
SIDECAR_DEVICE=cpu             # cpu | cuda

# --- Search ---
BM25_ENGINE=elasticsearch      # elasticsearch | postgres
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3
RRF_K=60
MIN_RELEVANCE_THRESHOLD=0.25
