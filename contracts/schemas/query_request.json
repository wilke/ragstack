{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_request.json",
  "title": "QueryRequest",
  "description": "Full RAG pipeline query request with rewrite, retrieve, rerank, and generate.",
  "type": "object",
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string"
    },
    "top_k": {
      "type": "integer",
      "default": 5
    },
    "rewrite_strategies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["passthrough"]
    },
    "filters": {
      "type": "object",
      "default": {}
    },
    "use_graph": {
      "type": "boolean",
      "default": true
    },
    "stream": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": false
}
