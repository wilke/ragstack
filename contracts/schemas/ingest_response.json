{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ingest_response.json",
  "title": "IngestResponse",
  "description": "Response for a document ingestion job.",
  "type": "object",
  "required": ["job_id", "status"],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "chunk_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
